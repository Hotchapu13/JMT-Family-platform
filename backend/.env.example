# Django
DJANGO_SECRET_KEY=changeme-generate-a-long-random-string       # Django's cryptographic signing key
DJANGO_SETTINGS_MODULE=config.settings.development             # Which settings module to load
DJANGO_ALLOWED_HOSTS=example.com,www.example.com                # Comma-separated hostnames allowed in production

# JWT
JWT_SIGNING_KEY=changeme-generate-a-separate-long-random-string  # Signing key for viewer/admin JWTs (kept distinct from DJANGO_SECRET_KEY)

# Database (PostgreSQL)
DB_NAME=jmt_legacy_dev                                          # Database name
DB_USER=jmt_dev                                                 # Database user
DB_PASSWORD=changeme                                             # Database password
DB_HOST=localhost                                                # Database host
DB_PORT=5432                                                     # Database port

# Cloudinary (media storage — replaces local/S3 file storage entirely)
CLOUDINARY_CLOUD_NAME=changeme                                   # Cloudinary account cloud name
CLOUDINARY_API_KEY=changeme                                      # Cloudinary API key
CLOUDINARY_API_SECRET=changeme                                   # Cloudinary API secret

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0                       # Redis broker URL for Celery
CELERY_RESULT_BACKEND=redis://localhost:6379/0                   # Redis result backend for Celery

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000                        # Comma-separated list of allowed frontend origins

# Initial Editor-in-Chief seed (used by `manage.py seed_admin`)
INITIAL_ADMIN_USERNAME=muhumuza.ibra                              # Username for the seeded Editor-in-Chief account
INITIAL_ADMIN_PASSWORD=changeme                                   # Password for the seeded Editor-in-Chief account
INITIAL_ADMIN_EMAIL=                                              # Email for the seeded Editor-in-Chief account (optional)
